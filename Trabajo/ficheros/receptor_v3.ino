#include <LedControl.h>

const int botonPin = 7;      // Pin del pulsador
bool estadoBoton;
const int espera = 200;      // Unidad de tiempo Morse

// Pines para la Matriz LED 
const int DINpin = 12;
const int CSpin  = 11;
const int CLKpin = 10;

// Inicializar matriz con 1 dispositivo
LedControl lc = LedControl(DINpin, CLKpin, CSpin, 1);


unsigned long tiempoInicio = 0;
unsigned long duracionPulsacion = 0;
String secuenciaMorse = "";

char* letras[] = {
  ".-", "-...", "-.-.", "-..", ".", "..-.", "--.", "....", "..", ".---", 
  "-.-", ".-..", "--", "-.", "---", ".--.", "--.-", ".-.", "...", "-", 
  "..-", "...-", ".--", "-..-", "-.--", "--.."
};

char* numeros[] = {
  "-----", ".----", "..---", "...--", "....-", ".....", "-....", "--...", "---..", "----."
};

// Definición de caracteres (8 bytes por fila) para matriz
// Definición de caracteres A-Z (8 bytes por letra)
const uint8_t fuenteMorse[26][8] PROGMEM = {
  {0x18, 0x24, 0x42, 0x42, 0x7E, 0x42, 0x42, 0x42}, // A
  {0x7C, 0x22, 0x22, 0x3C, 0x22, 0x22, 0x7C, 0x00}, // B
