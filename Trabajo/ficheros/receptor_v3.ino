void setup() {
  lc.shutdown(0, false);       // Salir de modo ahorro
  lc.setIntensity(0, 8);       // Brillo (0-15)
  lc.clearDisplay(0);          // Limpiar matriz
  
  pinMode(botonPin, INPUT);
  Serial.begin(9600);
  Serial.println("Receptor Morse con Matriz 8x8 Listo...");
}

void loop() {
  estadoBoton = digitalRead(botonPin);

  // Detectar cuando se pulsa el botón
  if (estadoBoton == HIGH) {
    tiempoInicio = millis();
    while (digitalRead(botonPin) == HIGH); // Esperar a soltar
    duracionPulsacion = millis() - tiempoInicio;

    if (duracionPulsacion > 50) { // Anti-rebote
      if (duracionPulsacion < (espera * 1.5)) {
        secuenciaMorse += ".";
        Serial.print(".");
      } else {
        secuenciaMorse += "-";
        Serial.print("-");
      }
    }
    delay(50);
  }
  else 

  // Si pasa tiempo suficiente sin pulsar, traducimos
  if (secuenciaMorse.length() > 0 && (millis() - tiempoInicio > espera * 3)) {
    traducirYMostrar();
  }
}

void traducirYMostrar() {
  char letraEncontrada = ' ';
  bool encontrado = false;

  // Buscar en letras
  for (int i = 0; i < 26; i++) {
    if (secuenciaMorse == letras[i]) {
      letraEncontrada = 'A' + i;
      encontrado = true;
      break;
    }
  }

  // Buscar en números si no se encontró en letras
  if (!encontrado) {
    for (int i = 0; i < 10; i++) {
      if (secuenciaMorse == numeros[i]) {
        letraEncontrada = '0' + i;
        encontrado = true;
        break;
      }
    }
  }

  if (encontrado) {
    Serial.print(" -> ");
    Serial.println(letraEncontrada);
    mostrarEnMatriz(letraEncontrada);
  } else {
    Serial.println(" -> Error");
    lc.clearDisplay(0); // O mostrar una 'X' de error
  }
  
  secuenciaMorse = ""; // Limpiar para el siguiente caracter
}

// Función para mostrar el caracter en la matriz 8x8
void mostrarEnMatriz(char c) {
  lc.clearDisplay(0); // Limpiar matriz anterior
  if (c >= 'A' && c <= 'Z') {
    int indice = c - 'A';
    for (int i = 0; i < 8; i++) {
      // Leer el dibujo desde la memoria de programa (PROGMEM) y enviarlo a la matriz
      lc.setRow(0, i, pgm_read_byte(&(fuenteMorse[indice][i])));
    }
  }
  else if (c >= '0' && c <= '9') {
    int indice = c - '0';
    for (int i = 0; i < 8; i++) {
      lc.setRow(0, i, pgm_read_byte(&(numerosMorse[indice][i])));
    }
  }
}
