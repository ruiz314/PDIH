const uint8_t numerosMorse[10][8] PROGMEM = {
  {0x3C, 0x46, 0x4A, 0x52, 0x62, 0x42, 0x3C, 0x00}, // 0
  {0x18, 0x28, 0x08, 0x08, 0x08, 0x08, 0x3E, 0x00}, // 1
